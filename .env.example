# Google Analytics 4 — Measurement ID from GA4 Admin → Data Streams.
# Only loads in production builds (NODE_ENV === 'production'), so local dev
# traffic never reaches your GA4 property. Set this value in Vercel Project
# Settings → Environment Variables for production + preview deployments.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Meta Pixel (Facebook Pixel) — Pixel ID from Meta Events Manager.
# Production-only and consent-gated: pixel initializes with consent revoked
# and only sends events after the cookie banner Accept. Required for Meta
# advertising campaigns. Set this in Vercel Project Settings → Environment
# Variables for production + preview deployments.
NEXT_PUBLIC_META_PIXEL_ID=000000000000000
